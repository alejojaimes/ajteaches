generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Author {
  id               String   @id @default(cuid())
  clerkUserId      String?  @unique
  name             String
  username         String?  @unique
  avatar           String?
  bio              String?
  headline         String?
  email            String?
  website          String?
  linkedinUrl      String?
  githubUrl        String?
  location         String?
  roles            String[] @default([])
  interests        String[] @default([])
  workHistory      Json     @default("[]")
  featuredPostSlug String?
  isOwner          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  posts            Post[]

  @@index([clerkUserId])
}

enum PostStatus {
  draft
  published
}

enum PostType {
  blog
  tutorial
}

model Post {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  excerpt          String?
  contentJson      Json?
  coverImage       String?
  status           PostStatus       @default(draft)
  postType         PostType         @default(blog)
  readTimeMinutes  Int              @default(1)
  readTimeOverride Int?
  authorId         String
  author           Author           @relation(fields: [authorId], references: [id])
  publishedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  shareLinks       DraftShareLink[]
  events           PostEvent[]
  tags             Tag[]
  likes            PostLike[]
  comments         Comment[]
  savedBy          SavedPost[]

  @@index([slug])
  @@index([status, publishedAt])
  @@index([authorId])
}

model DraftShareLink {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
}

enum EventType {
  view
  read_25
  read_50
  read_70
  read_100
  engagement_end
}

model PostEvent {
  id          String    @id @default(cuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  eventType   EventType
  sessionHash String
  durationMs  Int?
  createdAt   DateTime  @default(now())

  @@index([postId, eventType])
  @@index([createdAt])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  posts Post[]
}

model Reader {
  id          String     @id @default(cuid())
  clerkUserId String     @unique
  name        String
  email       String?
  githubUrl   String?
  phone       String?
  avatar      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  likes       PostLike[]
  comments    Comment[]
  savedPosts  SavedPost[]

  @@index([clerkUserId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  readerId  String
  reader    Reader   @relation(fields: [readerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, readerId])
  @@index([postId])
  @@index([readerId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  readerId  String
  reader    Reader    @relation(fields: [readerId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([postId, createdAt])
  @@index([readerId])
}

model SavedPost {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  readerId  String
  reader    Reader   @relation(fields: [readerId], references: [id], onDelete: Cascade)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([postId, readerId])
  @@index([postId])
  @@index([readerId])
}

model Subscriber {
  id                String    @id @default(cuid())
  email             String    @unique
  confirmed         Boolean   @default(false)
  confirmationToken String?   @unique
  unsubscribeToken  String    @unique
  subscribedAt      DateTime  @default(now())
  confirmedAt       DateTime?
  unsubscribedAt    DateTime?

  @@index([email])
  @@index([confirmed])
}
